{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "orderStatus": {
      "type": "enumeration",
      "default": "pending",
      "enum": [
        "pending",
        "delivered",
        "cancelled",
        "inprogress"
      ]
    },
    "pickupAddress": {
      "type": "string"
    },
    "deliveryAddress": {
      "type": "string"
    },
    "customerName": {
      "type": "string"
    },
    "customerPhone": {
      "type": "string"
    },
    "pickupLat": {
      "type": "decimal"
    },
    "pickupLag": {
      "type": "decimal"
    },
    "customer": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::customer.customer"
    },
    "users_permissions_users": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user",
      "inversedBy": "orders"
    },
    "price": {
      "type": "string"
    },
    "orderType": {
      "type": "string"
    },
    "notices": {
      "type": "text"
    }
  }
}
